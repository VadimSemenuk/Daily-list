{
  "extends": ["tslint:recommended", "tslint-react", "tslint-config-prettier"],
  "linterOptions": {
    "exclude": [
      "config/**/*.js",
      "node_modules/**/*.ts"
    ]
  },
  "jsRules":{
    "object-literal-sort-keys": false,
    "no-console": false,
    "no-shadowed-variable": false,
    "no-unused-expression": false,
    "no-bitwise": false
  }
}
